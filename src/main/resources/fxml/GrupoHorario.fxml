<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="560.0" prefWidth="922.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="visual.GrupoHorarioController">
    <children>
        <VBox layoutX="24.0" layoutY="50.0" prefHeight="250.0" prefWidth="220.0" spacing="10.0">
            <children>
                <Text strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-fill: #495057;" text="Día:">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Text>
                <ComboBox fx:id="cmbDia" prefHeight="26.0" prefWidth="220.0" style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 4px; -fx-background-radius: 4px;" />

                <Text strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-fill: #495057;" text="Hora Inicial:">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Text>
                <Spinner fx:id="spnHoraInicial" prefHeight="26.0" prefWidth="220.0" style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 4px;" />

                <Text strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-fill: #495057;" text="Hora Final:">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Text>
                <Spinner fx:id="spnHoraFinal" prefHeight="26.0" prefWidth="220.0" style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 4px;" />
            </children>
        </VBox>

        <TableView fx:id="tablaHorarios" layoutX="270.0" layoutY="32.0" prefHeight="496.0" prefWidth="620.0" style="-fx-border-color: #ced4da; -fx-border-radius: 4px;">
            <columns>
                <TableColumn fx:id="colCodPeriodoAcademico" prefWidth="125.0" text="Periodo Académico" />
                <TableColumn fx:id="colCodAsignatura" prefWidth="90.0" text="Asignatura" />
                <TableColumn fx:id="colNumGrupo" prefWidth="105.0" text="Número Grupo" />
                <TableColumn fx:id="colDia" prefWidth="85.0" text="Día" />
                <TableColumn fx:id="colHoraInicial" prefWidth="100.0" text="Hora Inicial" />
                <TableColumn fx:id="colHoraFinal" prefWidth="105.0" text="Hora Final" />
            </columns>
        </TableView>

        <Button fx:id="btnAsignar" layoutX="30.0" layoutY="340.0" mnemonicParsing="false" onAction="#btnAsignarClicked" prefHeight="38.0" prefWidth="95.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-cursor: hand;" text="Asignar" />
        <Button fx:id="btnEliminar" layoutX="140.0" layoutY="340.0" mnemonicParsing="false" onAction="#btnEliminarClicked" prefHeight="38.0" prefWidth="95.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-cursor: hand;" text="Eliminar" />
    </children>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="625.0" prefWidth="1117.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="visual.AsignaturaController">
   <children>
      <VBox layoutX="40.0" layoutY="56.0" prefHeight="200.0" prefWidth="120.0" spacing="20.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-fill: #495057;" text="Código Asignatura:">
               <font>
                  <Font size="14.0" />
               </font>
            </Text>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-fill: #495057;" text="Nombre:">
               <font>
                  <Font size="14.0" />
               </font>
            </Text>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-fill: #495057;" text="Créditos:">
               <font>
                  <Font size="14.0" />
               </font>
            </Text>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-fill: #495057;" text="Horas Teóricas:">
               <font>
                  <Font size="14.0" />
               </font>
            </Text>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-fill: #495057;" text="Horas Prácticas:">
               <font>
                  <Font size="14.0" />
               </font>
            </Text>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-fill: #495057;" text="Actividad:">
               <font>
                  <Font size="14.0" />
               </font>
            </Text>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-fill: #495057;" text="Usuario:">
               <font>
                  <Font size="14.0" />
               </font>
            </Text>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-fill: #495057;" text="Fecha y hora:">
               <font>
                  <Font size="14.0" />
               </font>
            </Text>
         </children>
      </VBox>
      <VBox layoutX="170.0" layoutY="56.0" prefHeight="292.0" prefWidth="266.0" spacing="12.0">
         <children>
            <TextField fx:id="fieldCodAsignatura" style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 4px; -fx-background-radius: 4px;" />
            <TextField fx:id="fieldNombre" style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 4px; -fx-background-radius: 4px;" />
            <Spinner fx:id="spnCreditos" prefWidth="266.0" style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 4px;" />
            <Spinner fx:id="spnHorasTeoricas" prefWidth="266.0" style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 4px;" />
            <Spinner fx:id="spnHorasPracticas" prefWidth="266.0" style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 4px;" />
            <TextField fx:id="fieldActividad" style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 4px; -fx-background-radius: 4px;" />
            <TextField fx:id="fieldUsuario" style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 4px; -fx-background-radius: 4px;" />
            <DatePicker fx:id="datePickerFechaHora" prefHeight="26.0" prefWidth="266.0" style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 4px;" />
         </children>
      </VBox>

      <TableView fx:id="tablaAsignaturas" layoutX="461.0" layoutY="56.0" prefHeight="521.0" prefWidth="625.0" style="-fx-border-color: #ced4da; -fx-border-radius: 4px;">
         <columns>
            <TableColumn fx:id="colCodigo" prefWidth="75.0" text="Código" />
            <TableColumn fx:id="colNombre" prefWidth="110.0" text="Nombre" />
            <TableColumn fx:id="colCreditos" prefWidth="60.0" text="Créditos" />
            <TableColumn fx:id="colHorasTeoricas" prefWidth="90.0" text="Horas Teóricas" />
            <TableColumn fx:id="colHorasPracticas" prefWidth="95.0" text="Horas Prácticas" />
            <TableColumn fx:id="colActividad" prefWidth="65.0" text="Actividad" />
            <TableColumn fx:id="colUsuario" prefWidth="65.0" text="Usuario" />
            <TableColumn fx:id="colFechaHora" prefWidth="63.0" text="Fecha y hora" />
         </columns>
      </TableView>

      <Button fx:id="btnInsertar" layoutX="60.0" layoutY="490.0" mnemonicParsing="false" onAction="#guardarAsignatura" prefHeight="38.0" prefWidth="100.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-cursor: hand;" text="Insertar" />
      <Button fx:id="btnActualizar" layoutX="180.0" layoutY="490.0" mnemonicParsing="false" onAction="#btnActualizarClicked" prefHeight="38.0" prefWidth="100.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-cursor: hand;" text="Actualizar" />
      <Button fx:id="btnEliminar" layoutX="300.0" layoutY="490.0" mnemonicParsing="false" onAction="#btnEliminarClicked" prefHeight="38.0" prefWidth="100.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-cursor: hand;" text="Eliminar" />

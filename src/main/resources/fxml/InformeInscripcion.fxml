<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="546.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="visual.ControlInforme">
   <children>
      <Label layoutX="14.0" layoutY="10.0" text="Visualizar informe de inscripción" style="-fx-text-fill: #333333;">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Label>
      <Label layoutX="47.0" layoutY="35.0" text="Seleccione un estudiante" style="-fx-text-fill: #495057;" />
      <ComboBox fx:id="cbxEstudiante" layoutX="47.0" layoutY="52.0" prefWidth="150.0" style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 4px; -fx-background-radius: 4px;" />
      <Label layoutX="220.0" layoutY="35.0" text="Seleccione periodo" style="-fx-text-fill: #495057;" />
      <ComboBox fx:id="cbxPeriodo" layoutX="220.0" layoutY="52.0" prefWidth="150.0" style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 4px; -fx-background-radius: 4px;" />
      <Button fx:id="btnVerInforme" layoutX="390.0" layoutY="50.0" mnemonicParsing="false" onAction="#generarInforme" prefHeight="30.0" prefWidth="110.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-cursor: hand;" text="Ver informe" />

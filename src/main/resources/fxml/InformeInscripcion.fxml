<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="428.0" prefWidth="594.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="visual.ControlInforme">
   <children>
      <Label layoutX="14.0" layoutY="10.0" style="-fx-text-fill: #333333;" text="Visualizar informe de inscripción">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Label>
      <Label layoutX="47.0" layoutY="35.0" style="-fx-text-fill: #495057;" text="Seleccione un estudiante" />
      <ComboBox fx:id="cbxEstudiante" layoutX="47.0" layoutY="52.0" prefWidth="150.0" style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 4px; -fx-background-radius: 4px;" />
      <Label layoutX="220.0" layoutY="35.0" style="-fx-text-fill: #495057;" text="Seleccione periodo" />
      <ComboBox fx:id="cbxPeriodo" layoutX="220.0" layoutY="52.0" prefWidth="150.0" style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 4px; -fx-background-radius: 4px;" />
      <Button fx:id="btnVerInforme" layoutX="390.0" layoutY="50.0" mnemonicParsing="false" onAction="#generarInforme" prefHeight="30.0" prefWidth="110.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-cursor: hand;" text="Ver informe" />
      <TextArea fx:id="txtReporte" editable="false" layoutX="47.0" layoutY="95.0" prefHeight="280.0" prefWidth="505.0" style="-fx-border-color: #ced4da; -fx-border-radius: 4px; -fx-font-family: 'Monospaced';" />
      <Button fx:id="btnCerrar" layoutX="460.0" layoutY="383.0" mnemonicParsing="false" onAction="#cerrar" prefHeight="30.0" prefWidth="80.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-cursor: hand;" text="Cerrar" />
   </children>
</AnchorPane>

      <Button fx:id="btnCerrar" layoutX="450.0" layoutY="345.0" mnemonicParsing="false" onAction="#cerrar" prefHeight="30.0" prefWidth="80.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-cursor: hand;" text="Cerrar" />
   </children>

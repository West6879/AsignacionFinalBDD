      <DatePicker fx:id="dpLimRetiro" layoutX="175.0" layoutY="230.0" prefHeight="26.0" prefWidth="150.0" style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 4px;" />

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootPane" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="visual.PaginaPrincipalController">
   <children>
      <!-- VBox alineado al CENTRO exacto de la pantalla -->
      <VBox alignment="CENTER" spacing="30.0">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>

            <!-- Título Principal -->
            <Label text="Asignación Final" style="-fx-text-fill: #333333; -fx-font-weight: bold;">
               <font>
                  <Font size="32.0" />
               </font>
            </Label>

            <!-- Cuadrícula de Botones Centrada -->
            <GridPane alignment="CENTER" hgap="20.0" vgap="20.0">
               <children>
                  <!-- Fila 1 -->
                  <Button mnemonicParsing="false" onAction="#insertarEstudiante" prefHeight="55.0" prefWidth="140.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="Estudiante" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <Button mnemonicParsing="false" onAction="#insertarAsignatura" prefHeight="55.0" prefWidth="140.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="Asignatura" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                  <Button mnemonicParsing="false" onAction="#btnCrearGrupo" prefHeight="55.0" prefWidth="140.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="Crear Grupo" GridPane.columnIndex="2" GridPane.rowIndex="0" />

                  <!-- Fila 2 -->
                  <Button mnemonicParsing="false" onAction="#btnGrupo" prefHeight="55.0" prefWidth="140.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="Adm. grupos" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <Button fx:id="btnInscribir" mnemonicParsing="false" onAction="#btnInscribir" prefHeight="55.0" prefWidth="140.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="Inscribir" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Button mnemonicParsing="false" onAction="#btnCrearPeriodo" prefHeight="55.0" prefWidth="140.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="Crear periodo" GridPane.columnIndex="2" GridPane.rowIndex="1" />

                  <!-- Fila 3 -->
                  <Button mnemonicParsing="false" onAction="#btnVerInforme" prefHeight="55.0" prefWidth="140.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="Informe" GridPane.columnIndex="1" GridPane.rowIndex="2" />
               </children>
            </GridPane>

         </children>
      </VBox>
   </children>
</StackPane>
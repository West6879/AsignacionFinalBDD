<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="410.0" prefWidth="540.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="visual.ControlInscribir">
    <children>
        <Label layoutX="14.0" layoutY="10.0" style="-fx-text-fill: #333333;" text="Inscripción de grupos">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>

        <Button fx:id="btnVerHorario" layoutX="414.0" layoutY="10.0" mnemonicParsing="false" onAction="#btnVerHorarioClicked" prefHeight="30.0" prefWidth="102.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-cursor: hand;" text="Ver horario" />

        <Label layoutX="34.0" layoutY="46.0" style="-fx-text-fill: #495057;" text="Seleccione un estudiante" />
        <ComboBox fx:id="cbxEst" layoutX="34.0" layoutY="65.0" prefHeight="26.0" prefWidth="132.0" style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 4px; -fx-background-radius: 4px;" />

        <Label layoutX="177.0" layoutY="46.0" style="-fx-text-fill: #495057;" text="Periodo" />
        <ComboBox fx:id="cbxPeriodo" layoutX="177.0" layoutY="65.0" prefHeight="26.0" prefWidth="102.0" style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 4px; -fx-background-radius: 4px;" />

        <Label layoutX="34.0" layoutY="115.0" style="-fx-text-fill: #495057; -fx-font-weight: bold;" text="Grupos disponibles" />
        <TableView fx:id="tvGrupDisp" layoutX="34.0" layoutY="135.0" prefHeight="200.0" prefWidth="246.0" style="-fx-border-color: #ced4da; -fx-border-radius: 4px;">
            <columns>
                <TableColumn fx:id="colDispId" prefWidth="50.0" text="No." />
                <TableColumn fx:id="colDispNombre" prefWidth="100.0" text="Materia" />
                <TableColumn fx:id="colDispHorario" prefWidth="94.0" text="Horario" />
            </columns>
        </TableView>

        <Label layoutX="300.0" layoutY="46.0" style="-fx-text-fill: #495057; -fx-font-weight: bold;" text="Grupos inscritos" />
        <TableView fx:id="tvGrupInsc" layoutX="300.0" layoutY="65.0" prefHeight="270.0" prefWidth="216.0" style="-fx-border-color: #ced4da; -fx-border-radius: 4px;">
            <columns>
                <TableColumn fx:id="colInscId" prefWidth="55.0" text="No." />
                <TableColumn fx:id="colInscNombre" prefWidth="158.0" text="Materia" />
            </columns>
        </TableView>

        <Button fx:id="btnAgregar" layoutX="158.0" layoutY="355.0" mnemonicParsing="false" onAction="#agregarGrupo" prefHeight="35.0" prefWidth="122.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-cursor: hand;" text="Agregar grupo" />
        <Button fx:id="btnEliminar" layoutX="300.0" layoutY="355.0" mnemonicParsing="false" onAction="#eliminarInscripcion" prefHeight="35.0" prefWidth="135.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-cursor: hand;" text="Eliminar inscripción" />
        <Button fx:id="btnSalir" layoutX="446.0" layoutY="355.0" mnemonicParsing="false" onAction="#salir" prefHeight="35.0" prefWidth="70.0" style="-fx-background-color: white; -fx-border-color: #007bff; -fx-border-width: 2px; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-text-fill: #007bff; -fx-font-weight: bold; -fx-cursor: hand;" text="Salir" />
    </children>
</AnchorPane>
